# ── Client environment (Vite) ─────────────────────────────────────────────────
# All client-exposed vars MUST be prefixed VITE_. Never put secrets here — anything
# here ships to the browser. Copy to `.env` and fill in.

# Base URL of the API. Client and API now share one Vercel origin, so this stays
# /api in every environment (dev via the Vite proxy, prod via the same deployment).
VITE_API_BASE_URL=/api

# The default location id (single-site deploy). MUST match DEFAULT_LOCATION_ID on the server
# and the id created by server/prisma/seed.js (the seed uses a fixed UUID so this stays
# stable across environments — do not regenerate it).
VITE_DEFAULT_LOCATION_ID=11111111-1111-1111-1111-111111111111

# Web Push public (VAPID) key — the PUBLIC half only. Generate with `npm run gen:vapid`
# in the server package and paste the public key here.
VITE_VAPID_PUBLIC_KEY=BGf46NKbvvizI_r1_xOSqriyuFCud7RTksQRRgdIwNdfHylbaHyYBoKSib8-ng3Jxiffup9HaP0YPmL8HlaGWmI
